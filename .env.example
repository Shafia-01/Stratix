# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
SERPAPI_KEY=your_serpapi_key_here

# MySQL Database Configuration
MYSQL_HOST=127.0.0.1
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=gemkey_ai
MYSQL_PORT=3306

# SEO Configuration
DATAFORSEO_USERNAME=your_dataforseo_username_here
DATAFORSEO_PASSWORD=your_dataforseo_password_here
DATAFORSEO_BASE_URL=https://api.dataforseo.com/v3
DATAFORSEO_DEBUG=true
DATAFORSEO_DEMO_MODE=true

# LangSmith (required for Phase 3 observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=keylytics-phase3
KEYLYTICS_ENV=development
