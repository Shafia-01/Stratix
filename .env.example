# Core APIs
GEMINI_API_KEY=your_gemini_api_key_here
SERPAPI_KEY=your_serpapi_key_here

# DataForSEO
DATAFORSEO_USERNAME=your_dataforseo_username
DATAFORSEO_PASSWORD=your_dataforseo_password
DATAFORSEO_DEMO_MODE=true
DATAFORSEO_PRESERVE_CREDITS=true
DATAFORSEO_LOW_BALANCE_THRESHOLD=0.50
DATAFORSEO_FORCE_SANDBOX=false

# LangSmith
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=keylytics-phase3

# Application
STRATIX_ENV=development
STRATIX_DB_PATH=keylytics.db
STRATIX_LOG_LEVEL=INFO
API_BASE_URL=http://localhost:8000

# API Authentication (leave empty to disable auth in development)
STRATIX_API_KEY=your_api_key_here
